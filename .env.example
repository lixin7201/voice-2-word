PORT=8127
PUBLIC_BASE_URL=http://lixindemac-studio.local:8127
DATA_FILE=data/dev-db.json
UPLOAD_DIR=uploads
EXPORT_DIR=exports
JWT_SECRET=change-me-in-local-env

# Optional backend fallback values. Prefer configuring these in the admin
# settings page after login; never put them in Chrome extension files.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_MODEL=fun-asr
DASHSCOPE_VOCABULARY_ID=
DASHSCOPE_POLL_INTERVAL_MS=5000
DASHSCOPE_TIMEOUT_MS=46800000
EASYAI_API_KEY=
EASYAI_BASE_URL=https://aisoeasy.cc/v1
EASYAI_MODEL=gpt-5.5
SUB2API_API_KEY=
SUB2API_BASE_URL=http://127.0.0.1:8080/v1
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-k2.6
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Local-only smoke testing. Set to 1 to generate template summaries without calling ASR/LLM.
VOICE_TO_WORD_DEV_FAKE_ASR=0

# Optional: comma-separated extra browser origins allowed to call the backend.
# Chrome extension origins and PUBLIC_BASE_URL are allowed automatically.
CORS_ALLOWED_ORIGINS=
